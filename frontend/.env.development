# DEVELOPMENT ONLY - SUPER FAST LOAD OPTIMIZATIONS

# Disable all validations & checks
ESLINT_NO_DEV_ERRORS=true
DISABLE_TSLINT_PLUGIN=true
DISABLE_SOURCE_MAPS=true
DISABLE_WEBPACK_DEV_SERVER_HOST_CHECK=true

# Speed up webpack compilation
DEV_TOOL=eval
WDS_SOCKET_PORT=0
WEBPACK_DEV_SERVER_HTTPS=false

# Disable unused features
REACT_APP_EDITOR=none
BUILD_NO_CHUNK=true

# Fast refresh optimizations
